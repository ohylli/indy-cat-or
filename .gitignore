# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv / virtualenv
.venv/

# Detector weights, auto-downloaded by ultralytics into the working directory.
*.pt

# Data & caches: large, reproducible, not for version control.
# Keep the folder and its READMEs, ignore everything else inside.
/data/*
!/data/README.md
!/data/embeddings/
/data/embeddings/*
!/data/embeddings/README.md

# claude
.claude/

# Indy photos: committed and published (CC BY-NC 4.0, see images/indy/LICENSE),
# with the owner's permission.

# Oxford-IIIT Pet: downloaded negatives, local only (like the Indy photos).
/images/oxford-iiit-pet/

# Cat-breeds (Kaggle ma7555): downloaded eval negatives, local only (1.9 GB).
/images/cat-breeds/

# Streamlit app static dir: a local copy of the photos for the data-review
# app's data grid, synced from images/indy at runtime — reproducible.
/scripts/data_review/static/

# Playwright MCP run artifacts (snapshots, console logs) from manual UI testing.
/.playwright-mcp/