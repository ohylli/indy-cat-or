# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# uv / virtualenv
.venv/

# Detector weights, auto-downloaded by ultralytics into the working directory.
*.pt

# Data & caches: large, reproducible, not for version control.
# Keep the folder and its READMEs, ignore everything else inside.
/data/*
!/data/README.md
!/data/embeddings/
/data/embeddings/*
!/data/embeddings/README.md

# claude
.claude/

# Indy photos: kept local only, not committed. The CSV metadata is tracked.
/images/indy/*
!/images/indy/mapping.csv

# Streamlit app static dir: a local copy of the photos for the review
# experiment's data grid, synced from images/indy at runtime — reproducible.
/experiments/static/